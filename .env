# =============================================================================
# Scalable Web Scraping Pipeline — Environment Configuration
# =============================================================================

# --- Scraper Settings ---
BASE_URL=https://books.toscrape.com
ACTIVE_PARSER=books
TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=2
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# --- Output Settings ---
OUTPUT_FOLDER=output
LOG_FOLDER=logs
LOG_LEVEL=INFO

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=5000
SECRET_KEY=change-this-to-a-secure-random-string
DEBUG=True

# --- Database Settings (Optional — leave empty to skip PostgreSQL) ---
DB_URL=
# Example: DB_URL=postgresql://user:password@localhost:5432/scraping_db

# --- Rate Limiting ---
REQUEST_DELAY=1
