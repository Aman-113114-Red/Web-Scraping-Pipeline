# =============================================================================
# Scalable Web Scraping Pipeline — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- Scraper Settings ---
# Base URL of the website to scrape (used by the active parser)
BASE_URL=https://books.toscrape.com

# Active parser module name (without _parser.py suffix)
# Available: books, quotes, jobs
ACTIVE_PARSER=books

# HTTP request timeout in seconds
TIMEOUT=30

# Maximum number of retry attempts for failed requests
MAX_RETRIES=3

# Delay between retries in seconds (exponential backoff applied)
RETRY_DELAY=2

# User-Agent header for HTTP requests
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# --- Output Settings ---
# Folder for CSV/JSON output files
OUTPUT_FOLDER=output

# Folder for log files
LOG_FOLDER=logs

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- API Settings ---
# Host and port for the Flask API server
API_HOST=0.0.0.0
API_PORT=5000

# Secret key for Flask sessions (change in production!)
SECRET_KEY=change-this-to-a-secure-random-string

# Enable Flask debug mode (set to False in production)
DEBUG=True

# --- Database Settings (Optional) ---
# PostgreSQL connection URL. Leave empty to skip database storage.
DB_URL=
# Example: DB_URL=postgresql://user:password@localhost:5432/scraping_db

# --- Rate Limiting ---
# Delay between consecutive HTTP requests in seconds
REQUEST_DELAY=1
